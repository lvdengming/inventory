{
  "name": "inventory",
  "version": "0.0.1",
  "private": true,
  "description": "物品清单管理应用",
  "scripts": {
    "dev": "umi dev",
    "build": "umi build",
    "build:pwa": "cross-env BUILD_MODE=pwa umi build",
    "build:h5": "cross-env BUILD_MODE=h5 umi build",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "postinstall": "umi setup"
  },
  "dependencies": {
    "@iconify/react": "^6.0.2",
    "@umijs/plugins": "^4.1.0",
    "umi": "^4.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "cross-env": "^7.0.3",
    "prettier": "3.8.3",
    "prettier-plugin-package": "^2.0.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.0.0"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "trailingComma": "all",
    "singleQuote": true,
    "plugins": [
      "prettier-plugin-package"
    ]
  }
}
